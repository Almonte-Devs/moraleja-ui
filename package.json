{
  "name": "@moraleja/ui",
  "version": "0.0.1",
  "description": "Componentes React del ecosistema Moraleja — Button, TextField, AuthMarketingPanel, Heading. Leen tokens desde @moraleja/tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react,react-dom,next",
    "dev": "tsup src/index.ts --format esm --dts --watch --external react,react-dom,next",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "design-system",
    "moraleja",
    "mira",
    "react",
    "tailwind",
    "shadcn"
  ],
  "author": "Editorial Moraleja",
  "license": "UNLICENSED",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Almonte-Devs/moraleja-ui.git"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "next": ">=14",
    "@moraleja/tokens": "*"
  },
  "peerDependenciesMeta": {
    "@moraleja/tokens": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.470.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
